{{< core/modal }}
{{$title}}{{#str}} widgetsselector, tiny_snippet {{/str}}{{/title}}
    {{$body}}
<div id="tiny_snippet_widgets_selectorpanel" class="tiny_snippet_widgets_selectorpanel">
    <form class="tiny_snippet_form" id="{{uniqid}}_tiny_snippet_form">
        <div class="root tab-content">
          <div>{{#str}} widgetsselector_instructions, tiny_snippet {{/str}}</div>
            {{#groups}}
            <div class="tiny_snippet_widget_group">
                <h5 class="tiny_snippet_widget_group_title">{{groupname}}</h5>
                {{#widgets}}
                <div class="tiny_snippet_widget_buttons">
                    <button data-templateindex="{{templateindex}}" class="tiny_snippet_widgetchoosebutton btn btn-info">{{name}}</button>
                </div>
                {{/widgets}}
            </div>
            {{/groups}}
        </div>
    </form>
</div>
<div id="tiny_snippet_widgets_optionspanel" class="tiny_snippet_widgets_optionspanel tiny_snippet_hidden">
</div>
    {{/body}}
    {{$footer}}
        <button type="button" class="btn btn-secondary" data-action="cancel">{{#str}} cancel {{/str}}</button>
    {{/footer}}
{{/ core/modal }}